# ---------------------------------------------------------------------------
# Rent & Flatmate Finder — environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# Supabase (required) — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to the browser

# LLM — Groq (optional; without it, scoring uses the rule-based fallback)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b

# Email notifications (optional). Priority: Resend > SMTP > log-only.
# 1) Resend — https://resend.com  (free tier)
RESEND_API_KEY=
EMAIL_FROM=Rent & Flatmate Finder <onboarding@resend.dev>

# 2) Local SMTP (e.g. Mailpit/Mailhog on port 1025). Used only if RESEND_API_KEY is empty.
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
